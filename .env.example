# Local development environment

# PostgreSQL/PostGIS connection for `make db-init` and migrations.
# Use psycopg3 (SQLAlchemy driver) explicitly.
DATABASE_URL=postgresql+psycopg://bgrealestate:bgrealestate@localhost:5432/bgrealestate

# Read-only URL for Cursor/PostgreSQL MCP inspection.
READONLY_DATABASE_URL=postgresql+psycopg://bgrealestate_readonly:bgrealestate@localhost:5432/bgrealestate

# Redis for rate limits, locks, queues, and realtime fanout.
REDIS_URL=redis://localhost:6379/0

# Temporal for durable crawl, enrichment, CRM sync, and publishing workflows.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# S3-compatible storage. MinIO is recommended locally.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=bgrealestate
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Optional source credentials. Do not commit real secrets.
OLX_API_CLIENT_ID=
OLX_API_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
AIRDNA_API_KEY=
AIRBTICS_API_KEY=

# Publishing integrations must remain official/authorized only.
BOOKING_CONNECTIVITY_CLIENT_ID=
BOOKING_CONNECTIVITY_CLIENT_SECRET=
AIRBNB_PARTNER_CLIENT_ID=
AIRBNB_PARTNER_CLIENT_SECRET=
