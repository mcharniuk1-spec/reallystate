# Local development environment

# Python dev API (`make run-api`, default http://127.0.0.1:8000). Used by Next.js server components and /api/backend proxy.
API_BASE_URL=http://127.0.0.1:8000
API_HOST=127.0.0.1
API_PORT=8000

# FastAPI CORS (comma-separated origins) when the browser calls the API directly.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LAN demo: add your machine IP and port, e.g. http://192.168.1.10:3000
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.10:3000

# Chat assistant: `stub` (default, no network) or `openai` when OPENAI_API_KEY is set.
CHAT_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional observability (wire in app code or process manager as needed).
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
DEPLOY_STAGE=local_dev

# API auth / RBAC for protected backend routes.
# Format: {"api-key-1":["listings:read","crm:read"],"api-key-2":["admin:read","crm:write"]}
API_KEYS_JSON=
# Optional convenience keys (auto-mapped scopes if API_KEYS_JSON is empty)
READONLY_API_KEY=
ADMIN_API_KEY=

# PostgreSQL/PostGIS connection for `make db-init` and migrations.
# Use psycopg3 (SQLAlchemy driver) explicitly.
DATABASE_URL=postgresql+psycopg://bgrealestate:bgrealestate@localhost:5432/bgrealestate

# Read-only URL for Cursor/PostgreSQL MCP inspection.
READONLY_DATABASE_URL=postgresql+psycopg://bgrealestate_readonly:bgrealestate@localhost:5432/bgrealestate

# Redis for rate limits, locks, queues, and realtime fanout.
REDIS_URL=redis://localhost:6379/0

# Temporal for durable crawl, enrichment, CRM sync, and publishing workflows.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=bgrealestate-main
ENABLE_TEMPORAL_RUNTIME=0
# Set to 0 to fail fast instead of falling back in --once checks.
ALLOW_TEMPORAL_FALLBACK=1

# S3-compatible storage. MinIO is recommended locally.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=bgrealestate
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# On-disk cache for downloaded listing images (Postgres holds metadata in listing_media).
# See src/bgrealestate/services/media.py and docs/docker-and-database.md.
MEDIA_STORAGE_PATH=data/media

# Optional source credentials. Do not commit real secrets.
HTTP_PROXY=
HTTPS_PROXY=
PLAYWRIGHT_BROWSERS_PATH=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
FIRECRAWL_API_KEY=
ZYTE_API_KEY=
ZYTE_API_URL=https://api.zyte.com/v1/extract
OLX_API_CLIENT_ID=
OLX_API_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
AIRDNA_API_KEY=
AIRBTICS_API_KEY=

# Publishing integrations must remain official/authorized only.
BOOKING_CONNECTIVITY_CLIENT_ID=
BOOKING_CONNECTIVITY_CLIENT_SECRET=
AIRBNB_PARTNER_CLIENT_ID=
AIRBNB_PARTNER_CLIENT_SECRET=
