ww.olx.bg/d/ad/prodava-se-uyutna-karavana-s-veranda-v-kamping-atliman-kray-kiten-CID368-ID9VjSN.html?search_reason=search%7Corganic", "external_id": "146886481", "listing_intent": "rent", "property_category": "other", "city": "", "district": "", "resort": null, "region": "", "address_text": "", "latitude": null, "longitude": null, "area_sqm": 20.0, "rooms": null, "floor": null, "total_floors": null, "year_built": null, "construction_type": null, "amenities": [], "price": 23000.0, "currency": "EUR", "description": "Предлагаме за продажба напълно оборудвана каравана, разположена в къмпинг „Атлиман“ край Китен, в близост до ВИП зоната. Имотът е с изложение Изток-Запад. Той се намира под естествената сянка на дърветата, в тихата и просторна част на къмпинга, с усещане за въздух и спокойствие. Зоната е предимно с каравани на собственици, което осигурява поддържана и спокойна среда. Караваната се продава в състояние „влизаш и живееш“ - напълно готова за лично ползване или за незабавно отдаване под наем, без необходимост от допълнителни инвестиции. Задължително прехвърляне при нотариус с договор. Цената за наем в къмпинга за летния сезон е 1900 евро. Разпределение и удобства: - Две големи легла, подходящи за четирима възрастни - Покрита веранда с площ 20 кв.м, изградена и изолирана с термопанели, които ефективно спират слънцето и осигуряват прохлада през горещите летни дни. - Верандата разполага с изцяло оборудвана кухня - печка, хладилник, посуда и кухненско оборудване, както и ъглова мека мебел с маса за големи компании. - Собствена тоалетна с възможност да се преустрои и в баня - Телевизор и ТВ шкаф - Заден двор с люлка - отделено и спокойно пространство - Паркомясто за един автомобил Локацията съчетава близост до плаж и тишина, което я прави еднакво подходяща за лично ползване и за доходоносна инвестиция. Къмпинг „Атлиман“ се намира на 50 метра от Северния плаж на Китен. Пространството е затворено, спокойно и добре поддържано, с рецепция и постоянна поддръжка. В къмпинга има детски площадки и широки зелени площи, което го прави много подходящ за семейства с деца и домашни любимци. Разположен е сред гора и високи дървета, които осигуряват естествена сянка и прохлада. Локацията е комуникативна и удобна, с магазин на територията на къмпинга и лесен достъп, без усещане за шум или пренаселеност.", "image_urls": ["/api/local-media/OLX.bg_146886481/0000_df0388ad.webp", "/api/local-media/OLX.bg_146886481/0001_f1f9a9e3.webp", "/api/local-media/OLX.bg_146886481/0002_d9f1193f.webp", "/api/local-media/OLX.bg_146886481/0003_3ed85cf3.webp"], "local_image_files": ["data/media/OLX.bg_146886481/0000_df0388ad.webp", "data/media/OLX.bg_146886481/0001_f1f9a9e3.webp", "data/media/OLX.bg_146886481/0002_d9f1193f.webp", "data/media/OLX.bg_146886481/0003_3ed85cf3.webp"], "photo_count_remote": 6, "photo_count_local": 6, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 1808, "description_quality": "rich", "scrape_quality_score": 85, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:05.882934+00:00", "last_seen": "2026-04-24T07:53:05.882934+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:05.882934+00:00", "photo_download_status": "full_gallery"}}, {"reference_id": "OLX.bg:146896004", "title": "Продава самостоятелна Къща,с.Гара Елин Пелин,област София", "source_name": "OLX.bg", "source_key": "olx_bg", "owner_group": null, "listing_url": "https://www.olx.bg/d/ad/prodava-samostoyatelna-kascha-s-gara-elin-pelin-oblast-sofiya-CID368-ID9Vmmo.html?search_reason=search%7Cpromoted", "external_id": "146896004", "listing_intent": "sale", "property_category": "house", "city": "", "district": "", "resort": null, "region": "", "address_text": "", "latitude": null, "longitude": null, "area_sqm": 279.0, "rooms": null, "floor": null, "total_floors": null, "year_built": null, "const