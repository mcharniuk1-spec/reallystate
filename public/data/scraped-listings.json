ите части на деня. Сградата е газифицирана. Локацията е изключително удобна, на 3 до 4 минути пешеходно разстояние от трето и четвърто училища, както и от целодневна детска градина. На 7 до 8 минути от езикова и природо-математическа гимназия, както и в близост до хранителни магазини, паркове и спортни съоръжения. Отличен избор за хора, които търсят просторен дом с възможност за завършване и персонализация по собствен вкус. Имотът е с един собственик и изряден документ за собственост. Цената търпи разумен коментар след оглед на имота. За допълнителна информация и организиране на оглед: „ХЕЛИОС-М – брокер недвижими имоти“. Телефони за контакт: 0=8=8=8=2=1=0=4=2=8 и 0=9=6=3=0=7=0=6=0. Агенцията предлага на своите клиенти пълен пакет от консултантски, посреднически и юридически услуги при покупка, продажба и отдаване под наем на недвижими имоти. На ваше разположение е екип от квалифицирани брокери, адвокати и архитекти с дългогодишен опит в сферата на недвиж", "image_urls": ["/api/local-media/OLX.bg_147541822/0000_d6d4eed7.webp", "/api/local-media/OLX.bg_147541822/0001_0d9e7c9c.webp", "/api/local-media/OLX.bg_147541822/0002_f48a94a4.webp", "/api/local-media/OLX.bg_147541822/0003_f99ce2df.webp"], "local_image_files": ["data/media/OLX.bg_147541822/0000_d6d4eed7.webp", "data/media/OLX.bg_147541822/0001_0d9e7c9c.webp", "data/media/OLX.bg_147541822/0002_f48a94a4.webp", "data/media/OLX.bg_147541822/0003_f99ce2df.webp"], "photo_count_remote": 6, "photo_count_local": 6, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 2000, "description_quality": "rich", "scrape_quality_score": 100, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:11.684029+00:00", "last_seen": "2026-04-24T07:53:11.684029+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:11.684029+00:00", "photo_download_status": "full