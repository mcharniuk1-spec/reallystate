partment", "city": "Кючук Париж", "district": "", "resort": null, "region": "Кючук Париж", "address_text": "Кючук Париж", "latitude": null, "longitude": null, "area_sqm": null, "rooms": 2.0, "floor": null, "total_floors": null, "year_built": null, "construction_type": null, "amenities": [], "price": 124000.0, "currency": "EUR", "description": "Оферта №3657 Представяме ви двустаен обзаведен апартамент в кв. Кючук Париж, гр. Пловдив. Разпределение: дневна с трапезария и кухненски бокс, спалня, баня с тоалетна, коридор и тераса. Предлага се с всичко необходимо за нанасяне веднага - вградено кухненско с ел. уреди, холова гарнитура, спален комплект. В близост се намират училища, детски градини, паркове за отдих и разходка, големи търговски вериги. Входа на блока е добре поддържан, с контрол на достъп и видеонаблюдение. Към имота има прилежащо избено помещение. За повече информация, можете да се обадите на посочения телефон.", "image_urls": ["/api/local-media/OLX.bg_147375065/0000_888cfa84.webp", "/api/local-media/OLX.bg_147375065/0001_2c4460f7.webp", "/api/local-media/OLX.bg_147375065/0002_c78e4224.webp", "/api/local-media/OLX.bg_147375065/0003_cd131528.webp"], "local_image_files": ["data/media/OLX.bg_147375065/0000_888cfa84.webp", "data/media/OLX.bg_147375065/0001_2c4460f7.webp", "data/media/OLX.bg_147375065/0002_c78e4224.webp", "data/media/OLX.bg_147375065/0003_cd131528.webp"], "photo_count_remote": 6, "photo_count_local": 6, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 586, "description_quality": "ok", "scrape_quality_score": 85, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:07.406555+00:00", "last_seen": "2026-04-24T07:53:07.406555+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:07.406555+00:00", "photo_download_status": "full_gallery"}}, {"reference_id": "OLX.bg:147375689", "title": "Простор и потенциал - масивна триетажна къща с панорамна гледка", "source_name": "OLX.bg", "source_key": "olx_bg", "owner_group": null, "listing_url": "https://www.olx.bg/d/ad/prostor-i-potentsial-masivna-trietazhna-kascha-s-panoramna-gledka-CID368-ID9Yn9f.html?search_reason=search%7Corganic", "external_id": "147375689", "listing_intent": "sale", "property_category": "house", "city": "", "district": "", "resort": null, "region": "", "address_text": "", "latitude": null, "longitude": null, "area_sqm": 320.0, "rooms": null, "floor": null, "total_floors": null, "year_built": null, "construction_type": null, "amenities": [], "price": 85000.0, "currency": "EUR", "description": "ID 5857 Описание на имота Предлагаме за продажба масивна, монолитна триетажна къща, разположена в най-високата точка на село Ново Ботево. Благодарение на стратегическото си местоположение, имотът разкрива впечатляваща панорама към цялото населено място и живописната природа на Добруджанското плато. Имотът е с разгърната застроена площ (РЗП) от 320 кв.м. и разполага с прилежащо дворно място от 1100 кв.м. Къщата е проектирана с мисъл за простор, функционалност и комфорт. Вътрешно разпределение Първи и втори жилищни етажи: Седем просторни спални, голяма трапезария (подходяща за организирани събития и зали за хранене), напълно оборудвана кухня, широки коридори и два санитарни възела. Тераси: Четири открити панорамни тераси, които опасват имота. Допълнителни площи: Избено помещение и голямо таванско помещение. Таванският етаж е подготвен за обособяване на още 3 самостоятелни спални, което увеличава капацитета на имота. Техническо състояние Конструкция: Монолитно строителство с доказано качество. Покрив: Изцяло отремонтиран и в отлично състояние. Дограма: Сменена с нова PVC дограма във всички помещения. Обзавеждане: Къщата се предлага частично обзаведена, което позволява бързо нанасяне или адаптиране според нуждите на новия собственик. Локация и предимства Имотът съчетава спокойствието на селския живот с бърз достъп до големите градски центрове: 24 км от град Добрич. 33 км от град Варна и международното летище. Инвестиционен потенциал Освен за целогодишно живеене или ваканционен дом, имотът представлява отлична възможност за бизнес проект. Поради големия брой спални и наличието на просторна зала за събирания, къщата е изключително подходяща за: Семеен хотел или Къща за гости; Място за провеждане на тиймбилдинги, семейни тържества и събития; Детски рождени дни и зелени училища. Характеристики на имота: Тип строителство: Тухла/Бетон Етажност: 3 етажа + таван Двор: 1100 кв.м. Спални: 7 (с опция за 10) Изложение: Панорама към всички посоки За огледи и допълнителна информация:", "image_urls": ["/api/local-media/OLX.bg_147375689/0000_5ef12c62.webp", "/api/local-media/OLX.bg_147375689/0001_c6a4bdbc.webp", "/api/local-media/OLX.bg_147375689/0002_106ead30.webp", "/api/local-media/OLX.bg_147375689/0003_3fb4ca0d.webp"], "local_image_files": ["data/media/OLX.bg_147375689/0000_5ef12c62.webp", "data/media/OLX.bg_147375689/0001_c6a4bdbc.webp", "data/media/OLX.bg_147375689/0002_106ead30.webp", "data/media/OLX.bg_147375689/0003_3fb4ca0d.webp"], "photo_count_remote": 6, "photo_count_local": 6, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 2000, "description_quality": "rich", "scrape_quality_score": 85, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:07.534107+00:00", "last_seen": "2026-04-24T07:53:07.534107+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:07.534107+00:00", "photo_download_status": "full_gallery"}}, {"reference_id": "OLX.bg:147391832", "title": "оф.25472 Дизайнерски тристаен/ Съдийски", "source_name": "OLX.bg", "source_key": "olx_bg", "owner_group": null, "listing_url": "https://www.olx.bg/d/ad/of-25472-dizaynerski-tristaen-sadiyski-CID368-ID9YrlC.htm