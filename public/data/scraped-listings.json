ение, което може да се функционира на ток и дизел. Навеси и гаражи за абсолютно всички нужди за правилното складиране на техника и готов продукт и цялостното функциониране на процеса. Жилище за работници ( охрана, берачи и т.н. ). Интернет и видеонаблюдение. Градина е по изцяло Европейски стандарт, а качеството на плода, който ражда е неповторим. За повече информация позвънете на посочения телефон", "image_urls": ["/api/local-media/OLX.bg_143590235/0000_17f88d2a.webp", "/api/local-media/OLX.bg_143590235/0001_34b51696.webp", "/api/local-media/OLX.bg_143590235/0002_49798d07.webp", "/api/local-media/OLX.bg_143590235/0003_ed27f03e.webp"], "local_image_files": ["data/media/OLX.bg_143590235/0000_17f88d2a.webp", "data/media/OLX.bg_143590235/0001_34b51696.webp", "data/media/OLX.bg_143590235/0002_49798d07.webp", "data/media/OLX.bg_143590235/0003_ed27f03e.webp"], "photo_count_remote": 6, "photo_count_local": 6, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 1429, "description_quality": "rich", "scrape_quality_score": 70, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:05.220642+00:00", "last_seen": "2026-04-24T07:53:05.220642+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:05.220642+00:00", "photo_download_status": "full_gallery"}}, {"reference_id": "OLX.bg:144627108", "title": "Апартаменти двустайни и тристайни ОТ СОБСТВЕНИК", "source_name": "OLX.bg", "source_key": "olx_bg", "owner_group": null, "listing_url": "https://www.olx.bg/d/ad/apartamenti-dvustayni-i-tristayni-ot-sobstvenik-CID368-ID9MQ7i.html?search_reason=search%7Cpromoted", "external_id": "144627108", "listing_intent": "sale", "property_category": "apartment", "city": "", "district": "", "resort": null, "region": "", "address_text": "", "latitude": null, "longitude": null, "area_sqm": null, "rooms": null, "floor": nul