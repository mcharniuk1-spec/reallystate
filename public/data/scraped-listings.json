то е идеално съобразено с изискванията на БАБХ. 3. За ТРАЙНИ НАСАЖДЕНИЯ (Орехи, Бадеми, Лешници): Почвените характеристики и климатът в района са подходящи за черупкови култури, които не изискват интензивно поливане. 4. За РАЗШИРЯВАНЕ НА СТОПАНСКА ДЕЙНОСТ: Граничещ с активна ферма, парцелът е перфектен за изграждане на селскостопански складове, навеси за техника или кошари за животни. Готови и изрядни документи за продажба! За повече информация или оглед се свържете с мен на посочения телефон, имейл адрес или на съобщение, чрез сайта.", "image_urls": ["/api/local-media/OLX.bg_147017148/0000_68c0ab08.webp", "/api/local-media/OLX.bg_147017148/0001_bc8b5d71.webp", "/api/local-media/OLX.bg_147017148/0002_ee219ff5.webp", "/api/local-media/OLX.bg_147017148/0003_8d7684ff.webp"], "local_image_files": ["data/media/OLX.bg_147017148/0000_68c0ab08.webp", "data/media/OLX.bg_147017148/0001_bc8b5d71.webp", "data/media/OLX.bg_147017148/0002_ee219ff5.webp", "data/media/OLX.bg_147017148/0003_8d7684ff.webp"], "photo_count_remote": 5, "photo_count_local": 5, "full_gallery_downloaded": true, "photo_download_status": "full_gallery", "description_chars": 1547, "description_quality": "rich", "scrape_quality_score": 70, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:53:05.991267+00:00", "last_seen": "2026-04-24T07:53:05.991267+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:53:05.991267+00:00", "photo_download_status": "full_gallery"}}, {"reference_id": "OLX.bg:145844992", "title": "дава под наем Дава под наем Склад на Околовръстен път, 350 м2", "source_name": "OLX.bg", "source_key": "olx_bg", "owner_group": null, "listing_url": "https://www.olx.bg/d/ad/dava-pod-naem-dava-pod-naem-sklad-na-okolovrasten-pat-350-m2-CID368-ID9RVVA.html?search_reason=search%7Cpromoted", "external_id": "145844992", "listing_intent": "rent", "property_category": "other