даване под наем.\r\nРазпределението на имота включва: входно антре, всекидневна с кухненски бокс, балкон, две бани с тоалетни и две спални помещения.\r\n\r\nЛокацията е едно от най-големите предимства на имота, намира се в непосредствена близост до НБУ и метростанция 'Мизия'. Овча купел е един от най-бързоразвиващите се райони на София, известен със своята уредена инфраструктура и отлична комуникация.\r\nВ непосредствена близост се намират:\r\n- Метростанция и НБУ ;\r\n- Новият път към Околовръстен път ;\r\n- Болница Доверие ;\r\n- Множество магазини, заведения, училища и детски градини ;\r\n\r\nРайонът съчетава тихо и зелено обкръжение с бърз достъп до центъра на града, което го прави изключително търсен както за живеене, така и за инвестиция.\r\n\r\nАко проявявате интерес към този имот се свържете с нас на телефона посочен в обявата, като ще ви бъде необходим референтен номер на имота: 44903.\r\n\r\nЗа нашите клиенти сме подготвили:\r\n* богато портфолио от различни имоти в различни райони;\r\n* консултация със специалист недвижими имоти;\r\n* консултация с юрист свързана с подготовка на всички необходими документи;\r\n* консултация с кредитен консултант;\r\n* различни оферти за ипотечен или потребителски кредит;", "image_urls": ["https://g1.homes.bg/2026-04-08_2/118421058o.jpg", "https://g1.homes.bg/2026-04-08_2/118421059o.jpg", "https://g1.homes.bg/2026-04-08_2/118421060o.jpg", "https://g1.homes.bg/2026-04-08_2/118421063o.jpg"], "local_image_files": [], "photo_count_remote": 7, "photo_count_local": 0, "full_gallery_downloaded": false, "photo_download_status": "no_local_files", "description_chars": 1704, "description_quality": "rich", "scrape_quality_score": 85, "image_report_status": "missing", "image_report_md": null, "image_report_json": null, "first_seen": "2026-04-24T07:52:27.604524+00:00", "last_seen": "2026-04-24T07:52:27.604524+00:00", "last_changed_at": null, "removed_at": null, "parser_version": null, "crawl_provenance": {"scraped_at": "2026-04-24T07:52