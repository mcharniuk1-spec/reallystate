{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "postgres-readonly": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${env:READONLY_DATABASE_URL}"],
      "env": {
        "READONLY_DATABASE_URL": "${env:READONLY_DATABASE_URL}"
      }
    }
  }
}
